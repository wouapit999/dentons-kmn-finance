// Dentons KMN Finance — data model (Auth/RBAC/Users module + org scaffolding).
//
// Dev uses SQLite for zero-config local runs. For production, switch the
// datasource provider to "postgresql" and point DATABASE_URL at Postgres.
// Statuses are stored as strings (portable across SQLite/Postgres) and are
// constrained in the application layer (see src/lib/constants.ts).

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the rhel target is what Vercel's runtime needs.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id           String   @id @default(uuid())
  legalName    String
  baseCurrency String   @default("XAF")
  countryCode  String   @default("CM")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  offices     Office[]
  departments Department[]
  users       User[]
  roles       Role[]
  auditLogs   AuditLog[]

  accounts     Account[]
  journals     Journal[]
  fiscalYears  FiscalYear[]
  periods      AccountingPeriod[]
  entries      JournalEntry[]

  practiceAreas  PracticeArea[]
  clients        Client[]
  matters        Matter[]
  conflictChecks ConflictCheck[]
}

model Office {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  countryCode String   @default("CM")
  currency    String   @default("XAF")
  timezone    String   @default("Africa/Douala")
  createdAt   DateTime @default(now())

  company   Company    @relation(fields: [companyId], references: [id])
  userRoles UserRole[]

  @@index([companyId])
}

model Department {
  id        String   @id @default(uuid())
  companyId String
  name      String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  users   User[]

  @@index([companyId])
}

model User {
  id            String    @id @default(uuid())
  companyId     String
  departmentId  String?
  email         String
  phone         String?
  fullName      String
  status        String    @default("ACTIVE") // INVITED | ACTIVE | DISABLED
  locale        String    @default("en") // en | fr
  currency      String    @default("XAF")
  passwordHash  String
  mfaEnabled    Boolean   @default(false)
  mfaSecretEnc  String?
  lastLoginAt   DateTime?
  failedLogins  Int       @default(0)
  lockedUntil   DateTime?
  version       Int       @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  company        Company         @relation(fields: [companyId], references: [id])
  department     Department?     @relation(fields: [departmentId], references: [id])
  userRoles      UserRole[]
  approvalLimits ApprovalLimit[]
  sessions       Session[]
  loginAttempts  LoginAttempt[]
  auditLogs      AuditLog[]
  mattersLed     Matter[]        @relation("MatterPartner")

  @@unique([companyId, email])
  @@index([companyId])
}

model Role {
  id             String   @id @default(uuid())
  companyId      String
  key            String
  name           String
  description    String?
  isSystem       Boolean  @default(false)
  hierarchyLevel Int      @default(100)
  createdAt      DateTime @default(now())

  company         Company          @relation(fields: [companyId], references: [id])
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([companyId, key])
  @@index([companyId])
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique // resource:action, e.g. "invoice:approve"
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId   String
  roleId   String
  officeId String?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  office Office? @relation(fields: [officeId], references: [id])

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model ApprovalLimit {
  id        String   @id @default(uuid())
  userId    String
  resource  String
  currency  String   @default("XAF")
  maxAmount Decimal
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  tokenId   String    @unique // jti of the issued JWT
  ip        String?
  userAgent String?
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LoginAttempt {
  id        String   @id @default(uuid())
  userId    String?
  email     String
  ip        String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([email])
}

// Append-only audit log. The application never updates or deletes these rows.
model AuditLog {
  id         String   @id @default(uuid())
  companyId  String
  actorId    String?
  action     String
  entityType String
  entityId   String?
  before     String? // JSON string
  after      String? // JSON string
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  actor   User?   @relation(fields: [actorId], references: [id])

  @@index([companyId])
  @@index([entityType, entityId])
}

// ---------------------------------------------------------------------------
// General Ledger (Module 2)
// ---------------------------------------------------------------------------

// Chart of Accounts (tree). SYSCOHADA-aware for Cameroon (OHADA) while also
// carrying an IFRS category for IFRS reporting.
model Account {
  id             String   @id @default(uuid())
  companyId      String
  code           String
  name           String
  type           String // ASSET | LIABILITY | EQUITY | REVENUE | EXPENSE
  syscohadaClass String? // OHADA class, e.g. "1".."8"
  ifrsCategory   String?
  currency       String?
  isPostable     Boolean  @default(true)
  parentId       String?
  status         String   @default("ACTIVE") // ACTIVE | ARCHIVED
  createdAt      DateTime @default(now())

  company  Company       @relation(fields: [companyId], references: [id])
  parent   Account?      @relation("AccountTree", fields: [parentId], references: [id])
  children Account[]     @relation("AccountTree")
  lines    JournalLine[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Journal {
  id        String   @id @default(uuid())
  companyId String
  code      String
  name      String
  type      String // SALES | PURCHASES | BANK | CASH | GENERAL | PAYROLL | TRUST
  createdAt DateTime @default(now())

  company Company        @relation(fields: [companyId], references: [id])
  entries JournalEntry[]

  @@unique([companyId, code])
  @@index([companyId])
}

model FiscalYear {
  id        String   @id @default(uuid())
  companyId String
  name      String
  startDate DateTime
  endDate   DateTime
  status    String   @default("OPEN") // OPEN | CLOSED
  createdAt DateTime @default(now())

  company Company            @relation(fields: [companyId], references: [id])
  periods AccountingPeriod[]

  @@index([companyId])
}

model AccountingPeriod {
  id           String   @id @default(uuid())
  companyId    String
  fiscalYearId String
  seq          Int
  name         String
  startDate    DateTime
  endDate      DateTime
  status       String   @default("OPEN") // OPEN | CLOSED
  closedAt     DateTime?

  company    Company        @relation(fields: [companyId], references: [id])
  fiscalYear FiscalYear     @relation(fields: [fiscalYearId], references: [id])
  entries    JournalEntry[]

  @@index([companyId])
  @@index([fiscalYearId])
}

// A posted journal entry is immutable. Corrections are new reversing entries.
model JournalEntry {
  id          String    @id @default(uuid())
  companyId   String
  journalId   String
  periodId    String
  entryNo     String
  entryDate   DateTime
  description String?
  currency    String    @default("XAF")
  status      String    @default("POSTED") // DRAFT | POSTED | REVERSED
  postedAt    DateTime?
  createdById String?
  reversalOf  String?
  createdAt   DateTime  @default(now())

  company Company          @relation(fields: [companyId], references: [id])
  journal Journal          @relation(fields: [journalId], references: [id])
  period  AccountingPeriod @relation(fields: [periodId], references: [id])
  lines   JournalLine[]

  @@unique([companyId, entryNo])
  @@index([companyId])
  @@index([periodId])
  @@index([journalId])
}

model JournalLine {
  id          String  @id @default(uuid())
  entryId     String
  accountId   String
  debit       Decimal @default(0)
  credit      Decimal @default(0)
  description String?

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])

  @@index([entryId])
  @@index([accountId])
}

// ---------------------------------------------------------------------------
// Client & Matter Management (Module 3)
// ---------------------------------------------------------------------------

model PracticeArea {
  id        String   @id @default(uuid())
  companyId String
  name      String
  createdAt DateTime @default(now())

  company Company  @relation(fields: [companyId], references: [id])
  matters Matter[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Client {
  id             String    @id @default(uuid())
  companyId      String
  type           String // CORPORATE | INDIVIDUAL
  name           String
  email          String?
  phone          String?
  taxId          String?
  kycStatus      String    @default("PENDING") // PENDING | VERIFIED | REJECTED
  amlRisk        String    @default("LOW") // LOW | MEDIUM | HIGH
  conflictStatus String    @default("NOT_RUN") // NOT_RUN | CLEAR | POTENTIAL | BLOCKED
  status         String    @default("ACTIVE") // ACTIVE | INACTIVE
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  company        Company         @relation(fields: [companyId], references: [id])
  matters        Matter[]
  conflictChecks ConflictCheck[]

  @@index([companyId])
}

model Matter {
  id                  String   @id @default(uuid())
  companyId           String
  clientId            String
  code                String
  name                String
  practiceAreaId      String?
  responsiblePartnerId String?
  status              String   @default("OPEN") // OPEN | ON_HOLD | CLOSED
  currency            String   @default("XAF")
  openedAt            DateTime @default(now())
  createdById         String?
  createdAt           DateTime @default(now())

  company           Company       @relation(fields: [companyId], references: [id])
  client            Client        @relation(fields: [clientId], references: [id])
  practiceArea      PracticeArea? @relation(fields: [practiceAreaId], references: [id])
  responsiblePartner User?        @relation("MatterPartner", fields: [responsiblePartnerId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@index([clientId])
}

model ConflictCheck {
  id          String   @id @default(uuid())
  companyId   String
  clientId    String
  status      String // CLEAR | POTENTIAL | BLOCKED
  matches     String? // JSON list of matched names
  notes       String?
  checkedById String?
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}
