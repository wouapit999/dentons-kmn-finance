# --- Database ---
# Local dev uses SQLite (zero-config). For production use PostgreSQL, e.g.:
# DATABASE_URL="postgresql://user:pass@host:5432/dentons_kmn?schema=public"
DATABASE_URL="file:./dev.db"

# --- Auth ---
# Generate a strong secret: `openssl rand -base64 48`  (min 32 chars)
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Session lifetime (seconds). Default 8h.
SESSION_TTL_SECONDS="28800"

# --- App ---
NODE_ENV="development"
