# --- Database ---
# Local dev uses SQLite (zero-config). For production (Vercel) use PostgreSQL.
# DB_PROVIDER controls the Prisma datasource provider at build time:
#   - local dev:  leave unset (defaults to "sqlite")
#   - Vercel/prod: set DB_PROVIDER=postgresql
DB_PROVIDER="sqlite"

# Local (SQLite):
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL), e.g. Vercel Postgres / Neon / Supabase:
# DATABASE_URL="postgresql://user:pass@host:5432/dentons_kmn?sslmode=require"

# --- Auth ---
# Generate a strong secret: `openssl rand -base64 48`  (min 32 chars)
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Session lifetime (seconds). Default 8h.
SESSION_TTL_SECONDS="28800"

# --- App ---
NODE_ENV="development"

# --- AI (optional) ---
# Enables the AI Assistant: natural-language reporting + invoice OCR.
# Without it the rest of the app runs normally; AI features show a "not configured" notice.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=""
# Model used for AI features (vision-capable). Default: claude-sonnet-5
AI_MODEL="claude-sonnet-5"
